# Copy this file to `.env` and fill in your own values.
# `.env` is gitignored — never commit real keys.

# OpenAI (GPT-4o, fine-tuning, feature extractor)
OPENAI_API_KEY=

# Google Gemini
GEMINI_API_KEY=

# HuggingFace (needed to download gated models like CONCH, LLaMA)
HF_TOKEN=

# Local data layout (override defaults in dataset_info_and_paths.py)
VLM_ROOT_FOLDER_PATH=
VLM_RESULTS_PATH=
